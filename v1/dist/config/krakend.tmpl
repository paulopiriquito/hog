{
  "$schema": "https://www.krakend.io/schema/v2.5/krakend.json",
  "version": 3,
  "name": "{{ .service.service_name }}",
  "port": {{ .service.port }},
  "cache_ttl": "{{ .service.cache_ttl }}",
  "timeout": "{{ .service.timeout }}",
  {{ template "plugin-loader.tmpl" . }},
  "extra_config": {
    {{ template "telemetry-config.tmpl" . }},
    {{ template "cors-config.tmpl" . }},
    "plugin/http-server": {
      "name": [
        "hog-static-content"
        {{ if .service.use_oauth }}
        ,"hog-authenticator"
        {{ end }}
      ],
      {{ template "static-content.tmpl" . }}
      {{ if .service.use_oauth }}
      ,{{ template "authenticator.tmpl" . }}
      {{ end }}
    }
  },
  "endpoints": []
}
