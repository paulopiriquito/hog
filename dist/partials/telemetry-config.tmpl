"telemetry/logging": {
  "level": "{{ .service.log_level }}",
  "prefix": "[HOG]",
  "syslog": {{ .service.log_syslog }},
  "stdout": {{ .service.log_stdout }},
  "format": "{{ .service.log_format }}",
  "access_log": {{ .service.access_log }},
  "skip_paths": {{ marshal .service.skip_paths }},
  "trace_format": "{{ .service.trace_format }}",
  "tags": {
    "env": "{{ .service.log_tags.env }}",
    "service": "{{ .service.log_tags.service }}",
    "version": "{{ .service.log_tags.version }}"
    {{- range $key, $value := .service.log_tags }}
    {{- if and (ne $key "env") (ne $key "service") (ne $key "version") }}
    ,"{{ $key }}": "{{ $value }}"
    {{- end }}
    {{- end }}
  }
},
{{ if .service.otel_enabled }}
"telemetry/opentelemetry": {
  "service_name": "{{ .service.otel_service_name }}",
  "service_version": "{{ .service.service_version }}",
  "skip_paths": {{ marshal .service.skip_paths }},
  "metric_reporting_period": 30,
  "exporters": {
    "otlp": [{
      "name": "default-exporter",
      "host": "{{ .service.otel_exporter_host }}",
      "port": {{ .service.otel_exporter_port }},
      "use_http": {{ .service.otel_exporter_use_http }},
      "disable_metrics": {{ .service.otel_disable_metrics }},
      "disable_traces": {{ .service.otel_disable_traces }}
    }]
  },
  "layers": {
    "global": {
      "disable_metrics": {{ .service.otel_disable_metrics }},
      "disable_traces": {{ .service.otel_disable_traces }},
      "disable_propagation": false
    },
    "proxy": {
      "disable_metrics": {{ .service.otel_disable_metrics }},
      "disable_traces": {{ .service.otel_disable_traces }}
    },
    "backend": {
      "metrics": {
        "disable_stage": false,
        "round_trip": false,
        "read_payload": false,
        "detailed_connection": false
      },
      "traces": {
        "disable_stage": false,
        "round_trip": false,
        "read_payload": false,
        "detailed_connection": false,
        "report_headers": false
      }
    }
  }
},
{{ end }}
"telemetry/metrics": {
  "collection_time": "{{ .service.metrics_collection_time }}",
  "proxy_disabled": false,
  "router_disabled": false,
  "backend_disabled": false,
  "endpoint_disabled": false,
  "listen_address": "{{ .service.metrics_listen_address }}"
}
