{{/*
  Authenticator Plugin Configuration

  Configures the hog-authenticator plugin for OAuth/OIDC authentication.
  This should only be included when use_oauth is true.
*/}}
"hog-authenticator": {
  "idp": {
    "type": "{{ .service.idp_type }}",
    "issuer": "{{ .service.idp_issuer }}",
    "well-known": "/.well-known/openid-configuration",
    "client-id": "{{ env "IDP_CLIENT_ID" }}",
    "client-secret": "{{ env "IDP_CLIENT_SECRET" }}"
  },
  "config": {
    "simple-auth-url": "{{ .service.oauth_simple_auth_url }}",
    "token-url": "{{ .service.oauth_token_url }}",
    "logout-url": "{{ .service.oauth_logout_url }}",
    "user-info-url": "{{ .service.oauth_userinfo_url }}",
    "callback-url": "{{ .service.oauth_callback_url }}",
    "scopes": "{{ .service.oauth_scopes }}",
    "session-key": "{{ env "AUTH_COOKIE_KEY" }}",
    "session-cookie-name": "{{ .service.session_cookie_name }}"
  }
}
