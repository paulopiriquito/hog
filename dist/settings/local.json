{
  "service_name": "hog-gateway-local",
  "service_version": "latest",
  "port": 8080,
  "cache_ttl": "300s",
  "timeout": "30s",

  "log_level": "DEBUG",
  "log_format": "text",
  "log_stdout": true,
  "log_syslog": false,
  "access_log": true,
  "skip_paths": ["/__health", "/__debug"],
  "trace_format": "otel",
  "log_tags": {
    "env": "local",
    "service": "hog-gateway",
    "version": "latest"
  },

  "cors_allow_origins": ["http://localhost:3000", "http://localhost:8080", "http://localhost:8080", "http://127.0.0.1:3000", "http://127.0.0.1:8080"],
  "cors_allow_methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
  "cors_allow_headers": ["Origin", "Authorization", "Content-Type", "Accept", "X-Requested-With", "Cookie"],
  "cors_expose_headers": ["Content-Length", "Content-Type"],
  "cors_max_age": "12h",
  "cors_allow_credentials": true,

  "static_host": "http://web:8080",
  "static_path_prefix": "/*",
  "static_auth_required": false,

  "use_oauth": false,
  "idp_type": "oidc",
  "idp_issuer": "http://localhost:5556",
  "idp_client_id": "hog-gateway",
  "oauth_simple_auth_url": "/oauth/simple-auth",
  "oauth_token_url": "/oauth/token",
  "oauth_logout_url": "/oauth/logout",
  "oauth_userinfo_url": "/oauth/userinfo",
  "oauth_callback_url": "/oauth/callback",
  "oauth_scopes": "openid profile email groups",
  "session_cookie_name": "hog_session",

  "otel_enabled": false,
  "otel_service_name": "hog-gateway-local",
  "otel_exporter_host": "localhost",
  "otel_exporter_port": 4317,
  "otel_exporter_use_http": false,
  "otel_disable_metrics": false,
  "otel_disable_traces": false,
  "metrics_listen_address": ":8090",
  "metrics_collection_time": "30s"
}
