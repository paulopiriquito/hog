// =============================================================================
// Grafana Alloy Configuration for HOG Gateway Observability
// Collects: OTLP traces/metrics/logs from KrakenD gateway
// Exports to: Tempo (traces), Loki (logs), Prometheus (metrics)
// Note: Docker log collection disabled for Podman compatibility on macOS
// =============================================================================

// -----------------------------------------------------------------------------
// OTLP Receiver - Receives telemetry from KrakenD/HOG gateway
// -----------------------------------------------------------------------------
otelcol.receiver.otlp "default" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces  = [otelcol.processor.batch.default.input]
    metrics = [otelcol.processor.batch.default.input]
    logs    = [otelcol.processor.batch.default.input]
  }
}

// -----------------------------------------------------------------------------
// Batch Processor - Batches telemetry for efficient export
// -----------------------------------------------------------------------------
otelcol.processor.batch "default" {
  timeout = "1s"
  send_batch_size = 1024

  output {
    traces  = [otelcol.exporter.otlp.tempo.input]
    metrics = [otelcol.exporter.prometheus.default.input]
    logs    = [otelcol.exporter.loki.default.input]
  }
}

// -----------------------------------------------------------------------------
// Tempo Exporter - Send traces to Grafana Tempo
// -----------------------------------------------------------------------------
otelcol.exporter.otlp "tempo" {
  client {
    endpoint = "tempo:4317"
    tls {
      insecure = true
    }
  }
}

// -----------------------------------------------------------------------------
// Prometheus Exporter - Expose metrics for Prometheus scraping
// -----------------------------------------------------------------------------
otelcol.exporter.prometheus "default" {
  forward_to = [prometheus.remote_write.default.receiver]
}

// -----------------------------------------------------------------------------
// Prometheus Remote Write - Send metrics to Prometheus
// -----------------------------------------------------------------------------
prometheus.remote_write "default" {
  endpoint {
    url = "http://prometheus:9090/api/v1/write"
  }
}

// -----------------------------------------------------------------------------
// Loki Exporter - Send OTLP logs to Loki
// -----------------------------------------------------------------------------
otelcol.exporter.loki "default" {
  forward_to = [loki.write.default.receiver]
}

// -----------------------------------------------------------------------------
// Loki Writer - Send logs to Loki
// -----------------------------------------------------------------------------
loki.write "default" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}

// -----------------------------------------------------------------------------
// Prometheus Scrape - Scrape KrakenD metrics endpoint
// -----------------------------------------------------------------------------
prometheus.scrape "krakend_metrics" {
  targets = [
    {"__address__" = "hog:8090", "job" = "krakend", "service" = "hog-gateway"},
  ]
  forward_to = [prometheus.remote_write.default.receiver]
  scrape_interval = "15s"
}

// -----------------------------------------------------------------------------
// Self Monitoring - Alloy internal metrics
// -----------------------------------------------------------------------------
prometheus.scrape "alloy_self" {
  targets = [
    {"__address__" = "localhost:12345", "job" = "alloy"},
  ]
  forward_to = [prometheus.remote_write.default.receiver]
  scrape_interval = "60s"
}
