{
    "$schema": "https://www.krakend.io/schema/v2.5/krakend.json",
    "version": 3,
    "name": "Hog Gateway - Production",
    "port": 8080,
    "cache_ttl": "3600s",
    "timeout": "3s",
    "plugin": {
        "pattern": ".so",
        "folder": "/etc/krakend/plugins/"
    },
    "extra_config": {
        "telemetry/logging": {
            "level": "INFO",
            "prefix": "[KRAKEND]",
            "syslog": false,
            "stdout": true,
            "format": "json",
            "access_log": true,
            "skip_paths": ["/__health", "/__debug", "/metrics"],
            "trace_format": "datadog",
            "tags": {
                "env": "prod",
                "service": "hog-gateway",
                "version": "v1.0.0"
            }
        },
        "telemetry/opentelemetry": {
            "service_name": "hog-gateway",
            "service_version": "v1.0.0",
            "skip_paths": ["/__health", "/metrics"],
            "metric_reporting_period": 30,
            "exporters": {
                "otlp": [{
                    "name": "datadog-agent",
                    "host": "datadog-agent",
                    "port": 4317,
                    "use_http": false,
                    "disable_metrics": false,
                    "disable_traces": false
                }]
            },
            "layers": {
                "global": {
                    "disable_metrics": false,
                    "disable_traces": false,
                    "disable_propagation": false
                },
                "proxy": {
                    "disable_metrics": false,
                    "disable_traces": false
                },
                "backend": {
                    "metrics": {
                        "disable_stage": false,
                        "round_trip": false,
                        "read_payload": false,
                        "detailed_connection": false
                    },
                    "traces": {
                        "disable_stage": false,
                        "round_trip": false,
                        "read_payload": false,
                        "detailed_connection": false,
                        "report_headers": false
                    }
                }
            }
        },
        "telemetry/metrics": {
            "collection_time": "60s",
            "proxy_disabled": false,
            "router_disabled": false,
            "backend_disabled": false,
            "endpoint_disabled": false,
            "listen_address": ":8090"
        },
        "security/cors": {
            "allow_origins": ["*"],
            "allow_methods": ["POST", "GET", "PUT", "DELETE", "OPTIONS"],
            "allow_headers": ["Origin", "Authorization", "Content-Type"],
            "expose_headers": ["Content-Length"],
            "max_age": "12h"
        }
    },
    "endpoints": []
}
